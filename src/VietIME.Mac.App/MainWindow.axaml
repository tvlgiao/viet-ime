<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="VietIME.Mac.App.MainWindow"
        Title="VietIME"
        Width="420" Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16">

        <!-- Permission Card (chỉ hiện khi thiếu quyền) -->
        <Border x:Name="panelPermission" IsVisible="False"
                Background="#2AF38BA8" CornerRadius="12" Padding="18" Margin="0,0,0,10"
                BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="⚠" FontSize="18" Foreground="{StaticResource ErrorBrush}" />
                    <TextBlock Text=" Cần cấp quyền để hoạt động" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="VietIME cần 2 quyền hệ thống để bắt phím và gửi ký tự tiếng Việt:" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />

                <!-- Input Monitoring -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="dotInputMonitoring" Width="8" Height="8" Margin="0,0,6,0" Fill="{StaticResource ErrorBrush}" />
                            <TextBlock Text="Input Monitoring" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                        <TextBlock Text="Bắt phím nhấn toàn hệ thống" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}" Margin="14,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Mở Cài đặt" Padding="10,6"
                            Click="BtnOpenInputMonitoring_Click"
                            Background="{StaticResource SurfaceLightBrush}"
                            Foreground="{StaticResource TextBrush}" FontSize="11" />
                </Grid>

                <!-- Accessibility -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="dotAccessibility" Width="8" Height="8" Margin="0,0,6,0" Fill="{StaticResource ErrorBrush}" />
                            <TextBlock Text="Accessibility" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                        <TextBlock Text="Gửi ký tự tiếng Việt thay thế" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}" Margin="14,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Mở Cài đặt" Padding="10,6"
                            Click="BtnOpenAccessibility_Click"
                            Background="{StaticResource SurfaceLightBrush}"
                            Foreground="{StaticResource TextBrush}" FontSize="11" />
                </Grid>

                <Border Height="1" Background="{StaticResource SurfaceLightBrush}" Margin="0,0,0,12" />

                <TextBlock Text="Sau khi cấp quyền, nhấn nút bên dưới để kiểm tra lại và khởi động lại VietIME." FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />

                <Button x:Name="btnRecheckPermission" Content="✓ Kiểm tra lại quyền" Padding="14,8"
                        Click="BtnRecheckPermission_Click"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="#1E1E2E" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <!-- Status Card -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,10">
            <StackPanel>
                <!-- Logo + Name -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="42" Height="42" CornerRadius="10" Background="#14141C">
                        <TextBlock Text="V" FontSize="22" FontWeight="Bold" Foreground="#D72828"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,2,0,0" VerticalAlignment="Center">
                        <TextBlock Text="VietIME" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Bộ gõ Tiếng Việt cho macOS" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,0" />
                        <TextBlock Text="Tác giả: Đỗ Nam — Teacher THCS Duyên Thái" FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"
                                   FontStyle="Italic" />
                    </StackPanel>
                </StackPanel>

                <!-- Toggle + Status -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ToggleSwitch x:Name="toggleEnabled" Grid.Column="0"
                                  IsChecked="True" OnContent="" OffContent=""
                                  IsCheckedChanged="ToggleEnabled_Changed" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="statusDot" Width="8" Height="8"
                                 Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0" />
                        <TextBlock x:Name="txtStatus" Text="Đang bật" FontSize="13"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text=" — " Foreground="{StaticResource TextDimBrush}" FontSize="13" />
                        <TextBlock x:Name="txtEngine" Text="Telex" FontSize="13"
                                   Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>

                <!-- Error message -->
                <TextBlock x:Name="txtError" Text="" FontSize="12"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap" IsVisible="False"
                           Margin="0,0,0,6" />
            </StackPanel>
        </Border>

        <!-- Input Method Card -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="KIỂU GÕ" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />

                <RadioButton x:Name="rbTelex" IsChecked="True"
                             IsCheckedChanged="InputMethod_Changed" GroupName="InputMethod">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Telex" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="  aa=â  dd=đ  s=sắc"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="rbVNI"
                             IsCheckedChanged="InputMethod_Changed" GroupName="InputMethod"
                             Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="VNI" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="    6=â  9=đ  1=sắc"
                                   Foreground="{StaticResource TextDimBrush}" FontSize="11" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Shortcut Card -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="PHÍM TẮT" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />

                <!-- Shortcut Cmd+Opt+Z -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bật/tắt VietIME" FontSize="13"
                               VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="⌘" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text=" + " Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="⌥" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text=" + " Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="Z" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="Menlo" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="{StaticResource SurfaceLightBrush}" Margin="0,4,0,8" />

                <!-- Shortcut Cmd+Opt+Shift+Z -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tắt gõ tiếng Việt" FontSize="13"
                               VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="⌘" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text=" + " Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="⌥" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text=" + " Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="⇧" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <TextBlock Text=" + " Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="11" />
                        <Border Background="{StaticResource SurfaceLightBrush}" CornerRadius="6" Padding="8,3">
                            <TextBlock Text="Z" FontSize="11" Foreground="{StaticResource TextMutedBrush}" FontFamily="Menlo" />
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Warp-only Mode Card -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ToggleSwitch x:Name="toggleWarpOnly" Grid.Column="0"
                              IsChecked="False" OnContent="" OffContent=""
                              IsCheckedChanged="ToggleWarpOnly_Changed" />
                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Chỉ bật trong Warp" FontSize="13" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Khi active Warp: tự bật. App khác: tự tắt." FontSize="10"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update Card -->
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PHIÊN BẢN" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtCurrentVersion" Text="v1.0.7" FontSize="13"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="btnCheckUpdate" Grid.Column="1" Content="Kiểm tra cập nhật"
                            Click="BtnCheckUpdate_Click" Padding="14,8" VerticalAlignment="Center"
                            Background="{StaticResource SurfaceLightBrush}"
                            Foreground="{StaticResource TextBrush}" />
                </Grid>

                <!-- Checking spinner -->
                <StackPanel x:Name="panelChecking" IsVisible="False" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="⟳" FontSize="13" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text=" Đang kiểm tra..." FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>

                <!-- Up to date -->
                <StackPanel x:Name="panelUpToDate" IsVisible="False" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="✓" FontSize="13" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" />
                    <TextBlock Text=" Bạn đang dùng phiên bản mới nhất" FontSize="12"
                               Foreground="{StaticResource SuccessBrush}" />
                </StackPanel>

                <!-- Error -->
                <TextBlock x:Name="txtUpdateError" IsVisible="False" FontSize="12"
                           Foreground="{StaticResource ErrorBrush}" Margin="0,10,0,0" TextWrapping="Wrap" />

                <!-- Update available banner -->
                <Border x:Name="panelUpdateAvailable" IsVisible="False"
                        Background="#1A89B4FA" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="🎉" FontSize="14" />
                            <TextBlock Text=" Có phiên bản mới! " FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" />
                            <TextBlock x:Name="txtNewVersion" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}" />
                        </StackPanel>
                        <TextBlock x:Name="txtReleaseNotes" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextMutedBrush}" MaxLines="3"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnInstallUpdate" Grid.Column="0" Content="⬇ Cập nhật ngay"
                                    Click="BtnInstallUpdate_Click" Padding="14,8"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="#1E1E2E" FontWeight="SemiBold" />
                            <Button x:Name="btnViewRelease" Grid.Column="1" Content="Xem"
                                    Click="BtnViewRelease_Click" Padding="14,8" Margin="6,0,0,0"
                                    Background="{StaticResource SurfaceLightBrush}"
                                    Foreground="{StaticResource TextBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Download progress -->
                <StackPanel x:Name="panelDownloading" IsVisible="False" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="⬇ Đang tải bản cập nhật..." FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock x:Name="txtDownloadProgress" Text="" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="6,0,0,0" />
                    </StackPanel>
                    <ProgressBar x:Name="progressDownload" Minimum="0" Maximum="100" Value="0"
                                 Height="4" Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource SurfaceLightBrush}" />
                </StackPanel>

                <!-- Installing -->
                <StackPanel x:Name="panelInstalling" IsVisible="False" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="⟳" FontSize="13" Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text=" Đang cài đặt... App sẽ khởi động lại." FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="txtFooterVersion" Grid.Column="0" FontSize="10" VerticalAlignment="Center"
                       Foreground="{StaticResource TextDimBrush}" />

            <Button Grid.Column="1" Content="Ẩn" Click="BtnMinimize_Click"
                    Margin="0,0,6,0" Padding="14,8"
                    Background="{StaticResource SurfaceLightBrush}"
                    Foreground="{StaticResource TextBrush}" />
            <Button Grid.Column="2" Content="Thoát" Click="BtnExit_Click"
                    Padding="14,8"
                    Background="{StaticResource ErrorBrush}"
                    Foreground="#1E1E2E" FontWeight="SemiBold" />
        </Grid>

    </StackPanel>
    </ScrollViewer>
</Window>
